cat > .gitignore << 'EOF'
# Dépendances
node_modules/
.pnp
.pnp.js

# Variables d'environnement
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Build frontend
frontend/dist/
frontend/.vite/

# Logs
*.log
npm-debug.log*
logs/

# OS
.DS_Store
Thumbs.db

# VSCode
.vscode/settings.json
.vscode/launch.json

# Misc
*.tgz
.cache/
EOF
